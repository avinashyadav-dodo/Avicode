{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Create build directory (Windows)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "New-Item -ItemType Directory -Force '${workspaceFolder}\\build' | Out-Null"
      ],
      "presentation": {
        "reveal": "never",
        "panel": "dedicated"
      },
      "windows": {}
    },
    {
      "label": "Build Current C++ File (Windows)",
      "type": "shell",
      "command": "g++",
      "args": [
        "-std=c++17",
        "-Wall",
        "-Wextra",
        "-g",
        "${file}",
        "-o",
        "${workspaceFolder}\\build\\${fileBasenameNoExtension}.exe"
      ],
      "group": "build",
      "dependsOn": "Create build directory (Windows)",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [
        "$gcc"
      ],
      "windows": {
        "group": {
          "kind": "build",
          "isDefault": true
        }
      }
    },
    {
      "label": "Run Current C++ File (Windows)",
      "type": "shell",
      "command": "${workspaceFolder}\\build\\${fileBasenameNoExtension}.exe",
      "dependsOn": "Build Current C++ File (Windows)",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "windows": {}
    },
    {
      "label": "Build and Run with practice_io (Windows)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "& { g++ -std=c++17 -Wall -Wextra -g '${file}' -o '${workspaceFolder}\\build\\${fileBasenameNoExtension}.exe'; if ($LASTEXITCODE -eq 0) { Get-Content '${workspaceFolder}\\practice_io\\input.txt' | & '${workspaceFolder}\\build\\${fileBasenameNoExtension}.exe' | Set-Content '${workspaceFolder}\\practice_io\\output.txt'; Get-Content '${workspaceFolder}\\practice_io\\output.txt' } }"
      ],
      "dependsOn": "Create build directory (Windows)",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [
        "$gcc"
      ],
      "windows": {}
    },
    {
      "label": "Create build directory (Ubuntu)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "mkdir -p '${workspaceFolder}/build'"
      ],
      "presentation": {
        "reveal": "never",
        "panel": "dedicated"
      },
      "linux": {}
    },
    {
      "label": "Build Current C++ File (Ubuntu)",
      "type": "shell",
      "command": "g++",
      "args": [
        "-std=c++17",
        "-Wall",
        "-Wextra",
        "-g",
        "${file}",
        "-o",
        "${workspaceFolder}/build/${fileBasenameNoExtension}"
      ],
      "group": "build",
      "dependsOn": "Create build directory (Ubuntu)",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [
        "$gcc"
      ],
      "linux": {
        "group": {
          "kind": "build",
          "isDefault": true
        }
      }
    },
    {
      "label": "Run Current C++ File (Ubuntu)",
      "type": "shell",
      "command": "${workspaceFolder}/build/${fileBasenameNoExtension}",
      "dependsOn": "Build Current C++ File (Ubuntu)",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "linux": {}
    },
    {
      "label": "Build and Run with practice_io (Ubuntu)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "mkdir -p '${workspaceFolder}/build' && g++ -std=c++17 -Wall -Wextra -g '${file}' -o '${workspaceFolder}/build/${fileBasenameNoExtension}' && '${workspaceFolder}/build/${fileBasenameNoExtension}' < '${workspaceFolder}/practice_io/input.txt' > '${workspaceFolder}/practice_io/output.txt' && cat '${workspaceFolder}/practice_io/output.txt'"
      ],
      "dependsOn": "Create build directory (Ubuntu)",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [
        "$gcc"
      ],
      "linux": {}
    }
  ]
}